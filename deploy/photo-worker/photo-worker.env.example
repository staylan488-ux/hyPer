NODE_ENV=production
PHOTO_WORKER_HOST=127.0.0.1
PHOTO_WORKER_PORT=8788
PHOTO_WORKER_ALLOWED_ORIGINS=capacitor://localhost,https://your-private-worker-host.example
PHOTO_WORKER_REQUIRE_ALLOWLIST=1
PHOTO_WORKER_ALLOWED_USER_IDS=first-supabase-user-uuid,second-supabase-user-uuid
PHOTO_WORKER_MAX_CONCURRENT=1
PHOTO_WORKER_MAX_QUEUED=4
PHOTO_WORKER_COMMAND_TIMEOUT_MS=150000
PHOTO_WORKER_OPENAI_MODEL=gpt-5.6-sol
PHOTO_WORKER_OPENAI_EFFORT=high
PHOTO_WORKER_ANTHROPIC_MODEL=claude-opus-4-8
PHOTO_WORKER_ANTHROPIC_EFFORT=high
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

