<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>hyPer</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>app.hyper.mobile.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>app.hyper.mobile</string>
			</array>
		</dict>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>hyPer uses the camera to scan food barcodes and analyze food photos you choose to log.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>hyPer reads weight measurements you choose to share through Apple Health, including measurements written by EufyLife.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>hyPer can save completed workouts and routes to Apple Health when you choose to enable that feature.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>hyPer uses your location during an active run, including when the screen is locked, to measure route, distance, pace, and splits.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>hyPer uses your location during a run to measure route, distance, pace, and splits.</string>
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>RunTracking</key>
		<string>Precise location is needed during an active run to measure distance, pace, route, and split boundaries accurately.</string>
	</dict>
	<key>NSMotionUsageDescription</key>
	<string>hyPer uses motion data during an active run to improve movement and pause detection.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>hyPer lets you select food photos for nutrition analysis.</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSSupportsLiveActivities</key>
	<true/>
</dict>
</plist>
